```gitignore
# Build artifacts
dist/
build/
*.js
*.ts
*.html

# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage
coverage/
htmlcov/
.coverage

# Distribution / packaging
.Python
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.junit.xml
coverage.xml
*.cover
.hypothesis/

# Translations
*.mo
*.pot

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Celery
celerybeat-schedule
celerybeat.pid

# Sage
home/sage/.sage/
.sage_ipython_history

# Environments
.venv/
venv/
env/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```